set_property PACKAGE_PIN AB5 [get_ports RGMII_rx_ctl]
set_property PACKAGE_PIN AA7 [get_ports RGMII_rxc]
set_property -dict {PACKAGE_PIN Y5 SLEW FAST} [get_ports {RGMII_td[0]}]
set_property -dict {PACKAGE_PIN AA12 SLEW FAST} [get_ports {RGMII_td[1]}]
set_property -dict {PACKAGE_PIN AB12 SLEW FAST} [get_ports {RGMII_td[2]}]
set_property -dict {PACKAGE_PIN AB11 SLEW FAST} [get_ports {RGMII_td[3]}]
set_property -dict {PACKAGE_PIN AB10 SLEW FAST} [get_ports RGMII_tx_ctl]
set_property -dict {PACKAGE_PIN AA11 SLEW FAST} [get_ports RGMII_txc]
set_property PACKAGE_PIN AB1 [get_ports ENET0_EXT_INTIN]

set_property IOSTANDARD LVCMOS33 [get_ports ENET0_EXT_INTIN]

set_property PACKAGE_PIN M19 [get_ports ADC0_CLK_clk_p]
set_property PACKAGE_PIN M20 [get_ports ADC0_CLK_clk_n]
