set_property BITSTREAM.GENERAL.COMPRESS True [current_design]
set_property CFGBVS VCCO [current_design]
set_property CONFIG_VOLTAGE 3.3 [current_design]

set_property IOSTANDARD LVCMOS33 [get_ports MDIO_PHY_*]
set_property IOSTANDARD LVCMOS33 [get_ports RGMII_*]
set_property IOSTANDARD LVDS_25 [get_ports ADC0_CLK_*]
set_property IOSTANDARD LVDS_25 [get_ports ADC1_CLK_*]
set_property IOSTANDARD LVDS_25 [get_ports ADC0_OUT_*]
set_property IOSTANDARD LVDS_25 [get_ports ADC1_OUT_*]
set_property IOSTANDARD LVDS_25 [get_ports DAC_D_*]
set_property IOSTANDARD LVDS_25 [get_ports DAC_DCI_*]
set_property IOSTANDARD LVDS_25 [get_ports DAC_DCO_*]

create_clock -period 8.000 -name RGMII_rxc -waveform {0.000 4.000} [get_ports RGMII_rxc]
create_clock -period 8.000 -name RGMII_txc -waveform {0.000 4.000} [get_ports RGMII_txc]
create_clock -period 8.138 -name ADC1_CLK -waveform {0.000 4.069} [get_ports ADC1_CLK_clk_p]
set_input_jitter ADC1_CLK 0.1
create_clock -period 8.138 -name DAC_DCO -waveform {0.000 4.069} [get_ports DAC_DCO_P]
#False path constraints to async inputs coming directly to synchronizer
set_false_path -to [get_pins -hier -filter {name =~ *idelayctrl_reset_gen/*reset_sync*/PRE }]
set_false_path -to [get_pins -of [get_cells -hier -filter { name =~ *i_MANAGEMENT/SYNC_*/data_sync* }] -filter { name =~ *D }]
set_false_path -to [get_pins -hier -filter {name =~ *reset_sync*/PRE }]
#False path constraints from Control Register outputs
set_false_path -from [get_pins -hier -filter {name =~ *i_MANAGEMENT/DUPLEX_MODE_REG*/C }]
# constraint valid if parameter C_EXTERNAL_CLOCK = 0
set_case_analysis 0 [get_pins -hier -filter {name =~ *i_bufgmux_gmii_clk/CE0}]
set_case_analysis 0 [get_pins -hier -filter {name =~ *i_bufgmux_gmii_clk/S0}]
set_case_analysis 1 [get_pins -hier -filter {name =~ *i_bufgmux_gmii_clk/CE1}]
set_case_analysis 1 [get_pins -hier -filter {name =~ *i_bufgmux_gmii_clk/S1}]
# Use these constraints to modify input delay on RGMII signals
set_input_delay -clock [get_clocks RGMII_rxc] -max -1.500 [get_ports {{RGMII_rd[*]} RGMII_rx_ctl}]
set_input_delay -clock [get_clocks RGMII_rxc] -min -2.800 [get_ports {{RGMII_rd[*]} RGMII_rx_ctl}]
set_input_delay -clock [get_clocks RGMII_rxc] -clock_fall -max -add_delay -1.500 [get_ports {{RGMII_rd[*]} RGMII_rx_ctl}]
set_input_delay -clock [get_clocks RGMII_rxc] -clock_fall -min -add_delay -2.800 [get_ports {{RGMII_rd[*]} RGMII_rx_ctl}]
# Use these constraints to modify output delay on RGMII signals if 2ns delay is added by the core
set_output_delay -clock [get_clocks RGMII_txc] -max 0.750 [get_ports {{RGMII_td[*]} RGMII_tx_ctl}]
set_output_delay -clock [get_clocks RGMII_txc] -min -0.700 [get_ports {{RGMII_td[*]} RGMII_tx_ctl}]
set_output_delay -clock [get_clocks RGMII_txc] -clock_fall -max -add_delay 0.750 [get_ports {{RGMII_td[*]} RGMII_tx_ctl}]
set_output_delay -clock [get_clocks RGMII_txc] -clock_fall -min -add_delay -0.700 [get_ports {{RGMII_td[*]} RGMII_tx_ctl}]

set_property PACKAGE_PIN AB2 [get_ports MDIO_PHY_mdc]
set_property PACKAGE_PIN Y4 [get_ports MDIO_PHY_mdio_io]
set_property PACKAGE_PIN AB6 [get_ports {RGMII_rd[0]}]
set_property PACKAGE_PIN AB7 [get_ports {RGMII_rd[1]}]
set_property PACKAGE_PIN Y11 [get_ports {RGMII_rd[2]}]
